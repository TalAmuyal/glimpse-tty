{
  "name": "awrit-native-rs",
  "version": "2.0.0",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "BSD-3-Clause",
  "napi": {
    "name": "awrit-native-rs",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "make": "napi build --platform --release && node scripts/convert-types.js",
    "ci": "napi build --platform --release",
    "make:debug": "napi build --platform"
  }
}

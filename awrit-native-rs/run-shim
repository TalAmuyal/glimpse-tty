#!/bin/bash

# Check if any argument is provided
if [ $# -eq 0 ]; then
    echo "Error: No script provided"
    exit 1
fi

# Check for ../.bun/bin/bun
if [ -x "../.bun/bin/bun" ]; then
    exec "../.bun/bin/bun" "$@"
# Check for bun in PATH
elif command -v bun >/dev/null 2>&1; then
    exec bun "$@"
# Check for node in PATH
elif command -v node >/dev/null 2>&1; then
    exec node "$@"
else
    echo "Error: Neither bun nor node found in PATH"
    exit 1
fi

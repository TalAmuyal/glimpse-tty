{
  "name": "glimpse-tty",
  "version": "2.0.5",
  "description": "A full graphical web browser for Kitty terminal with mouse and keyboard support",
  "main": "index.js",
  "author": "Chase Colman",
  "maintainer": "Tal Amuyal",
  "license": "BSD-3-Clause",
  "homepage": "https://github.com/TalAmuyal/glimpse-tty",
  "engines": {
    "node": ">=22.11.0"
  },
  "workspaces": ["src/runner"],
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint ./src",
    "lint-fix": "biome lint --write ./src",
    "lint-fix-unsafe": "biome lint --write --unsafe ./src",
    "start": "echo 'You should run using `./glimpse-tty` or use the installer to install glimpse-tty' && exit 1",
    "input-test": "bun run ./src/tty/inputTest.ts",
    "gfx-test": "bun run ./src/tty/graphicsTest.ts",
    "bump-crossterm": "git subtree pull --prefix=glimpse-tty-native-rs/crates/crossterm --squash https://github.com/crossterm-rs/crossterm master",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "glimpse-tty-native-rs": "./glimpse-tty-native-rs",
    "electron": "^41.3.0",
    "electron-chrome-context-menu": "^1.1.0",
    "electron-chrome-extensions": "^4.9.0",
    "electron-chrome-web-store": "^0.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@sinonjs/fake-timers": "^14.0.0",
    "@types/node": "^24.3.0",
    "@types/sinonjs__fake-timers": "^8.1.5",
    "dompurify": "^3.4.1",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.2",
    "marked-alert": "^2.1.2",
    "marked-footnote": "^1.4.0",
    "marked-gfm-heading-id": "^4.1.4",
    "mermaid": "^11.14.0",
    "typescript": "^5.9.2"
  },
  "trustedDependencies": ["@biomejs/biome", "@tailwindcss/oxide", "glimpse-tty-native-rs", "core-js", "electron", "esbuild"],
  "patchedDependencies": {
    "lru-cache@5.1.1": "patches/lru-cache@5.1.1.patch"
  }
}

{
  "name": "awrit",
  "version": "2.0.0",
  "description": "A full graphical web browser for Kitty terminal with mouse and keyboard support",
  "main": "index.js",
  "author": "Chase Colman",
  "license": "BSD-3-Clause",
  "homepage": "https://github.com/chase/awrit",
  "engines": {
    "node": ">=22.11.0"
  },
  "workspaces": [
    "src/runner"
  ],
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint ./src",
    "lint-fix": "biome lint --write ./src",
    "lint-fix-unsafe": "biome lint --write --unsafe ./src",
    "start": "electron dist/index.cjs",
    "input-test": "bun run ./src/tty/inputTest.ts",
    "gfx-test": "bun run ./src/tty/graphicsTest.ts",
    "bump-crossterm": "git subtree pull --prefix=awrit-native-rs/crates/crossterm --squash https://github.com/crossterm-rs/crossterm master"
  },
  "dependencies": {
    "awrit-native": "github:chase/node-awrit-native#4c393f0c17a7b1837b542cc0b597e1baa7b3b5a5",
    "electron-chrome-context-menu": "^1.1.0",
    "electron-chrome-extensions": "^4.5.0",
    "electron-chrome-web-store": "^0.9.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^22.13.8",
    "electron": "35.0.0-beta.12",
    "typescript": "^5.8.2"
  },
  "trustedDependencies": ["@biomejs/biome", "awrit-native", "core-js", "electron", "esbuild"],
  "patchedDependencies": {
    "lru-cache@5.1.1": "patches/lru-cache@5.1.1.patch"
  }
}

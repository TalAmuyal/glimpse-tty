{
	"name": "glimpse-tty-native-rs",
	"version": "2.0.7",
	"main": "index.js",
	"types": "index.d.ts",
	"license": "BSD-3-Clause",
	"napi": {
		"binaryName": "glimpse-tty-native-rs",
		"targets": [
			"aarch64-apple-darwin",
			"x86_64-unknown-linux-gnu",
			"aarch64-unknown-linux-gnu"
		]
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.1.5"
	},
	"scripts": {
		"postinstall": "./run-shim scripts/download-binary.js",
		"artifacts": "napi artifacts",
		"make": "napi build --platform --release && ./run-shim scripts/fix-types.js",
		"ci": "napi build --platform --release",
		"make:debug": "napi build --platform && ./run-shim scripts/fix-types.js"
	}
}

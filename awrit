#!/usr/bin/env bash

set -e

# readlink -f but works on macOS too
resolve_link() {
  local target="$1"
  while [ -L "$target" ]; do
    target="$(readlink "$target")"
    if [[ "$target" != /* ]]; then
      target="$(dirname "$1")/$target"
    fi
  done
  echo "$target"
}

BASE_DIR=$(cd -- "$(dirname -- "$(resolve_link "${BASH_SOURCE:-$0}")")" &>/dev/null && pwd)

# Prefer a Bun on PATH (e.g. pinned by mise); fall back to the bootstrapped sandbox.
if command -v bun >/dev/null 2>&1; then
    BUN="$(command -v bun)"
else
    BUN="$BASE_DIR/.bun/bin/bun"
fi

if [ ! -d "$BASE_DIR/node_modules" ] || [ ! -x "$BUN" ]; then
    "$BASE_DIR/setup.sh"
fi

echo "shim" "$@" > "$BASE_DIR/awrit_error.txt"
exec -a awrit "$BUN" run "$BASE_DIR/src/runner" "$@" 2>"$BASE_DIR/awrit_error.txt"
